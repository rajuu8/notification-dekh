<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#0F172A"
    android:padding="24dp">

    <!-- Icon -->
    <LinearLayout
        android:layout_width="90dp"
        android:layout_height="90dp"
        android:background="#1E293B"
        android:gravity="center"
        android:layout_marginBottom="20dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎧"
            android:textSize="44sp"/>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="One Way Audio"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#F1F5F9"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_audio_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Phone 1 ready hai"
        android:textSize="14sp"
        android:textColor="#94A3B8"
        android:gravity="center"
        android:layout_marginBottom="32dp"/>

    <!-- Listening Animation -->
    <TextView
        android:id="@+id/tv_listening"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sun raha hai... 👂"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#16A34A"
        android:gravity="center"
        android:background="#0F2010"
        android:padding="16dp"
        android:layout_marginBottom="24dp"
        android:visibility="gone"/>

    <!-- Listen Button -->
    <Button
        android:id="@+id/btn_listen"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Sun na Shuru Karo 🎧"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2563EB"
        android:layout_marginBottom="12dp"
        style="@style/Widget.MaterialComponents.Button"/>

    <Button
        android:id="@+id/btn_stop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Band Karo"
        android:textSize="14sp"
        android:textColor="#EF4444"
        android:backgroundTint="#1E293B"
        android:enabled="false"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

</LinearLayout>
